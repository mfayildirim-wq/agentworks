# =============================================================================
# AgentWorks — environment configuration
# Copy this file to infra/.env and fill in the values. NEVER commit infra/.env.
#   cp infra/.env.example infra/.env
# Used by infra/docker-compose.prod.yml (and the dev compose for the DB/Redis ports).
# =============================================================================

# --- Public domain & TLS (production) ---------------------------------------
# Your public hostname (no scheme). Drives CORS, NEXTAUTH_URL, PUBLIC_BASE_URL,
# the Google OAuth redirect URI and the nginx-proxy/Let's-Encrypt routing.
PUBLIC_DOMAIN=your-domain.example.com
# E-mail used by Let's-Encrypt (acme-companion) for certificate notices.
LETSENCRYPT_EMAIL=admin@example.com
# Optional explicit override; defaults to https://${PUBLIC_DOMAIN}
# PUBLIC_BASE_URL=https://your-domain.example.com

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=agentworks
# Use a strong password in production (required by the prod compose).
POSTGRES_PASSWORD=change_me
POSTGRES_DB=agentworks
# Host ports only used by the dev compose (infra/docker-compose.yml).
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- Secrets (REQUIRED) -----------------------------------------------------
# Fernet key used to encrypt stored credentials (API keys, OAuth tokens, ...).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENT_SECRET_KEY=
# NextAuth session signing secret (frontend). Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=
# SearXNG instance secret (internal web search). Generate with:
#   openssl rand -hex 32
SEARXNG_SECRET=

# --- LLM provider API keys --------------------------------------------------
# At least one is required so agents can run. ANTHROPIC is the default provider.
ANTHROPIC_API_KEY=
# Optional, only if you offer OpenAI models.
OPENAI_API_KEY=
# Optional, only if you offer DeepSeek models (default model is deepseek-chat).
DEEPSEEK_API_KEY=
# Optional, embeddings provider for RAG/pgvector. Leave empty to disable.
VOYAGE_API_KEY=

# --- Google OAuth (optional: "Sign in with Google" + Calendar/Gmail) --------
# Create credentials in Google Cloud Console. Leave empty to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Defaults to https://${PUBLIC_DOMAIN}/oauth/google/callback ; for local dev use
# http://localhost:8000/oauth/google/callback . Must match the Cloud Console value.
# GOOGLE_OAUTH_REDIRECT_URI=

# --- Billing (optional) -----------------------------------------------------
# Stripe secret key for wallet top-ups. Leave empty to disable real payments.
STRIPE_SECRET_KEY=

# --- E-mail / SMTP notifications (optional) ---------------------------------
# Leave SMTP_HOST empty to disable the e-mail notification channel.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Sender address for outgoing notification e-mails.
MAIL_FROM=

# --- Telegram notifications (optional) --------------------------------------
# Bot token from @BotFather. Empty token disables the Telegram channel + poller.
TELEGRAM_BOT_TOKEN=
# Bot username (without @), used for the per-user deep-link.
TELEGRAM_BOT_USERNAME=

# --- Local model runtime (optional) -----------------------------------------
# A host-native Ollama instance for local models. Default points at the Docker
# bridge gateway so containers can reach Ollama running on the host.
OLLAMA_URL=http://172.17.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Misc -------------------------------------------------------------------
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Internal SearXNG endpoint (usually leave as is for the prod compose).
SEARXNG_URL=http://searxng:8080
